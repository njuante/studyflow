{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StudyFlow",
  "version": "0.2.2",
  "identifier": "com.procesozero.studyflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StudyFlow",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "transparent": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["mica"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["icons/badge/*.png"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/njuante/studyflow/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEN0RBREEzRjMwRUE4MzAKUldRd3FBN3pvNjE5amE5cklYdDZ3QUE2VGNqcXhTNTNPMlVuWEx0SWIxeVJnTFFqTmRHZUxMNFkK"
    }
  }
}
